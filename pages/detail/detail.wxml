<view class="container">
  <!-- 加载中 -->
  <view class="loading-wrap" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <!-- 错误状态 -->
  <view class="error-wrap" wx:if="{{!loading && error}}">
    <text class="error-text">{{errorMsg}}</text>
    <view class="error-actions">
      <button class="action-btn" bindtap="onRetry" size="mini" type="primary" plain>重试</button>
      <button class="action-btn" bindtap="onBackHome" size="mini" plain>返回首页</button>
    </view>
  </view>

  <!-- 新闻内容 -->
  <block wx:if="{{!loading && !error && news}}">
    <view class="news-header">
      <text class="news-title">{{news.title}}</text>
      <view class="news-meta">
        <text class="news-source">{{news.source}}</text>
        <text class="news-category">{{news.categoryLabel}}</text>
        <text class="news-time">{{news.publishTimeText}}</text>
      </view>
    </view>

    <view class="news-body">
      <text class="news-content">{{news.content}}</text>
      <view class="news-images" wx:if="{{news.images && news.images.length > 0}}">
        <image
          class="content-image"
          wx:for="{{news.images}}"
          wx:key="*this"
          src="{{item}}"
          mode="widthFix"
          lazy-load
          data-url="{{item}}"
          bindtap="onPreviewImage"
        />
      </view>
    </view>
  </block>
</view>
