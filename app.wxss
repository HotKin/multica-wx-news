/**app.wxss**/
page {
  --primary-color: #1890ff;
  --text-primary: #333;
  --text-secondary: #666;
  --text-muted: #999;
  --border-color: #e5e5e5;
  --bg-color: #f5f5f5;
  --bg-white: #fff;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
  background-color: var(--bg-color);
  color: var(--text-primary);
}

.container {
  padding: 20rpx;
}

.flex {
  display: flex;
}

.flex-1 {
  flex: 1;
}

.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.text-ellipsis-2 {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
